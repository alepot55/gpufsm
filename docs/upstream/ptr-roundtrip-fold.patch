@@ -260,3 +260,16 @@ tt.func @no_canonicalize_indivisible_offset(%base: tensor<128x!tt.ptr<f32>>) ->
   %result = tt.int_to_ptr %offset_ptr_int : tensor<128xi64> -> tensor<128x!tt.ptr<f32>>
   tt.return %result : tensor<128x!tt.ptr<f32>>
 }
+
+// -----
+
+// CHECK-LABEL: ptr_to_int_of_int_to_ptr
+tt.func @ptr_to_int_of_int_to_ptr(%x: tensor<16xi64>) -> tensor<16xi64> {
+  // ptr_to_int(int_to_ptr(x)) -> x
+  // CHECK-NOT: tt.int_to_ptr
+  // CHECK-NOT: tt.ptr_to_int
+  // CHECK: tt.return %arg0
+  %p = tt.int_to_ptr %x : tensor<16xi64> -> tensor<16x!tt.ptr<f32>>
+  %i = tt.ptr_to_int %p : tensor<16x!tt.ptr<f32>> -> tensor<16xi64>
+  tt.return %i : tensor<16xi64>
+}
