 // arith.bitcast doesn't support pointers
diff --git a/lib/Dialect/Triton/IR/Ops.cpp b/lib/Dialect/Triton/IR/Ops.cpp
index be3bc32..5e0cb86 100644
--- a/lib/Dialect/Triton/IR/Ops.cpp
+++ b/lib/Dialect/Triton/IR/Ops.cpp
@@ -1262,6 +1262,31 @@ void IntToPtrOp::getCanonicalizationPatterns(RewritePatternSet &results,
       context);
 }
 
+//-- PtrToIntOp --
+// ptr_to_int(int_to_ptr(val)) -> val
+// Mirror of CanonicalizeIntToPtrOfPtrToInt; eliminates the inverse round-trip.
+struct CanonicalizePtrToIntOfIntToPtr : public OpRewritePattern<PtrToIntOp> {
+  CanonicalizePtrToIntOfIntToPtr(MLIRContext *context)
+      : OpRewritePattern<PtrToIntOp>(context, 1) {}
+
+  LogicalResult matchAndRewrite(PtrToIntOp ptrToIntOp,
+                                PatternRewriter &rewriter) const override {
+    auto intToPtrOp = ptrToIntOp.getSrc().getDefiningOp<IntToPtrOp>();
+    if (!intToPtrOp)
+      return failure();
+    // A bitcast bridges any difference between the original integer type and
+    // this op's result type; a same-type bitcast folds away.
+    rewriter.replaceOpWithNewOp<BitcastOp>(ptrToIntOp, ptrToIntOp.getType(),
+                                           intToPtrOp.getSrc());
+    return success();
+  }
+};
+
+void PtrToIntOp::getCanonicalizationPatterns(RewritePatternSet &results,
+                                             MLIRContext *context) {
+  results.add<CanonicalizePtrToIntOfIntToPtr>(context);
+}
