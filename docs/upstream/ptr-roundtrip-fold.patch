diff --git a/include/triton/Dialect/Triton/IR/TritonOps.td b/include/triton/Dialect/Triton/IR/TritonOps.td
index 8bd4d6c..9701fd5 100644
--- a/include/triton/Dialect/Triton/IR/TritonOps.td
+++ b/include/triton/Dialect/Triton/IR/TritonOps.td
@@ -63,6 +63,7 @@ def TT_PtrToIntOp : TT_Op<"ptr_to_int", [Elementwise,
     let results = (outs TT_I64Like:$result);
 
     let assemblyFormat = "$src attr-dict `:` type($src) `->` type($result)";
+    let hasCanonicalizer = 1;
