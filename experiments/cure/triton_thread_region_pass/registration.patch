 }
 
+def TritonGPUThreadRegion: Pass<"tritongpu-thread-region", "mlir::ModuleOp"> {
+  let summary = "Detect lock-step irregular regions that forfeit intra-warp latency hiding";
+
+  let description = [{
+    Research pass (gpufsm "abstraction regret"). Detects the lock-step signature of a
+    data-dependent irregular region: an `scf.while` whose iter-args are `#blocked`-encoded
+    tile tensors and whose loop condition is gated by a `tt.reduce` to a scalar (the whole
+    tile loops to the busiest lane; idle lanes are masked). Marks each match with a
+    `ttg.thread_region_candidate` unit attribute and emits a remark. This is the detection
+    half of the proposed tile->thread (`thread_region`) lowering that recovers per-lane
+    intra-warp latency hiding; see docs/P2_PASS_DESIGN.md.
+  }];
+
+  let dependentDialects = ["mlir::triton::gpu::TritonGPUDialect",
+                           "mlir::triton::TritonDialect",
+                           "mlir::scf::SCFDialect"];
+}
+
 #endif
